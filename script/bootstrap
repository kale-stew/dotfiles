#!/usr/bin/env bash
#
# bootstrap — set up dotfiles on a fresh machine
#
# Usage:
#   git clone https://github.com/kale-stew/dotfiles.git ~/.dotfiles
#   cd ~/.dotfiles
#   script/bootstrap
#
# What it does:
#   1. Installs Homebrew (macOS) or stow via system package manager (Linux)
#   2. Generates ~/.gitconfig.local from the example template if missing
#   3. Symlinks all files in home/ into ~/ using GNU Stow
#   4. Symlinks git/ignore and git/attributes to ~/.config/git/
#   5. Installs all packages and apps listed in Brewfile (macOS only)

set -e

DOTFILES_ROOT="$(cd "$(dirname "$0")/.." && pwd -P)"

info()    { printf "  [ \\033[00;34m..\\033[0m ] %s\\n" "$1"; }
success() { printf "\\r\\033[2K  [ \\033[00;32mOK\\033[0m ] %s\\n" "$1"; }
fail()    { printf "\\r\\033[2K  [\\033[0;31mFAIL\\033[0m] %s\\n" "$1"; exit 1; }

# ------------------------------------------------------------------
# Homebrew (macOS)
# ------------------------------------------------------------------
install_homebrew() {
  if ! command -v brew &>/dev/null; then
    info "installing Homebrew"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    if [[ -x /opt/homebrew/bin/brew ]]; then
      eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [[ -x /usr/local/bin/brew ]]; then
      eval "$(/usr/local/bin/brew shellenv)"
    fi
  fi
}

# ------------------------------------------------------------------
# GNU Stow
# ------------------------------------------------------------------
ensure_stow() {
  if command -v stow &>/dev/null; then
    return
  fi

  info "installing GNU Stow"

  if [[ "$(uname -s)" == "Darwin" ]]; then
    install_homebrew
    brew install stow
  elif command -v apt-get &>/dev/null; then
    sudo apt-get update -qq && sudo apt-get install -y stow
  elif command -v pacman &>/dev/null; then
    sudo pacman -S --noconfirm stow
  elif command -v dnf &>/dev/null; then
    sudo dnf install -y stow
  else
    fail "unsupported package manager — install stow manually: https://www.gnu.org/software/stow/"
  fi

  success "stow installed"
}

# ------------------------------------------------------------------
# Local gitconfig (~/.gitconfig.local)
# ------------------------------------------------------------------
setup_gitconfig() {
  if [[ ! -f "$DOTFILES_ROOT/git/gitconfig.local.symlink" ]]; then
    info "creating git/gitconfig.local.symlink"
    cp "$DOTFILES_ROOT/git/gitconfig.local.symlink.example" \
       "$DOTFILES_ROOT/git/gitconfig.local.symlink"
    success "created — edit git/gitconfig.local.symlink with your name, email, and signing key"
  fi

  if [[ ! -L "$HOME/.gitconfig.local" ]]; then
    info "linking ~/.gitconfig.local"
    ln -sf "$DOTFILES_ROOT/git/gitconfig.local.symlink" "$HOME/.gitconfig.local"
    success "linked"
  fi
}

# ------------------------------------------------------------------
# Stow
# ------------------------------------------------------------------
link_dotfiles() {
  info "linking dotfiles to ~/"

  # Backup existing files that stow would conflict with
  for target in "$HOME/.gitconfig" "$HOME/.zshrc"; do
    if [[ -f "$target" && ! -L "$target" ]]; then
      cp "$target" "${target}.backup"
      rm "$target"
      info "backed up $target to ${target}.backup"
    fi
  done

  cd "$DOTFILES_ROOT"
  stow -R -t "$HOME" home/
  success "linked"
}

# ------------------------------------------------------------------
# XDG git config (~/.config/git/{ignore,attributes})
# ------------------------------------------------------------------
link_git_xdg() {
  info "linking git XDG config to ~/.config/git/"

  mkdir -p "$HOME/.config/git"

  for file in ignore attributes; do
    src="$DOTFILES_ROOT/git/$file"
    dst="$HOME/.config/git/$file"
    if [[ ! -L "$dst" ]]; then
      ln -sf "$src" "$dst"
    fi
  done

  success "git XDG config linked"
}

# ------------------------------------------------------------------
# Homebrew bundle
# ------------------------------------------------------------------
install_packages() {
  if [[ "$(uname -s)" != "Darwin" ]]; then
    info "skipping Brewfile (not macOS)"
    return
  fi

  install_homebrew

  info "installing Homebrew packages"
  cd "$DOTFILES_ROOT"
  brew bundle
  success "packages installed"
}

# ------------------------------------------------------------------
# Main
# ------------------------------------------------------------------
ensure_stow
setup_gitconfig
link_dotfiles
link_git_xdg
install_packages

echo ""
echo "  Done! Restart your shell or run: source ~/.zshrc"
